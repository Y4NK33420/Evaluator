# Copy to .env and fill in real values
# docker compose automatically reads .env

# ── Google GenAI (env-driven model routing) ───────────────────────────────────
AMGS_GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Required fallback model. App startup fails if this is not set.
AMGS_DEFAULT_MODEL=gemini-2.5-flash
DEFAULT_MODEL=gemini-2.5-flash

# Optional per-task model overrides (fallback to DEFAULT_MODEL when omitted)
SUBJECTIVE_OCR_MODEL=
OBJECTIVE_OCR_MODEL=
SUBJECTIVE_GRADING_MODEL=
OBJECTIVE_GRADING_MODEL=
RUBRICS_GENERATION_MODEL=
CODE_HEALING_MODEL=

# ── HuggingFace (optional — avoids rate limits on model downloads) ─────────
HF_TOKEN=
# Pinned Transformers commit used by custom vLLM image build.
TRANSFORMERS_REF=3a3b59cb1a7c0238c8d1072e35d3879c5faff48e

# ── App settings ────────────────────────────────────────────────────────────
DEBUG=false

# Model transient retry/backoff handling
MODEL_TRANSIENT_MAX_RETRIES=3
MODEL_RETRY_INITIAL_BACKOFF_SECONDS=1.5
MODEL_RETRY_MAX_BACKOFF_SECONDS=12

# Code-eval local execution (development only until containerized/microVM sandbox is wired)
CODE_EVAL_ENABLE_LOCAL_EXECUTION=true
CODE_EVAL_EXECUTION_BACKEND=local
CODE_EVAL_DOCKER_DEFAULT_IMAGE=python:3.11-slim
CODE_EVAL_DOCKER_FORCE_NO_NETWORK=true
CODE_EVAL_DOCKER_AUTO_PULL=true
CODE_EVAL_ENABLE_SHIM_RETRY=true
CODE_EVAL_ENABLE_AI_SHIM_GENERATION=false
CODE_EVAL_MICROVM_ENABLE_ADAPTER=false
CODE_EVAL_MICROVM_RUNTIME_MODE=pending
CODE_EVAL_MICROVM_ALLOW_FALLBACK=true
CODE_EVAL_MICROVM_FALLBACK_BACKEND=docker
CODE_EVAL_MICROVM_FORCE_NO_NETWORK=true
CODE_EVAL_MICROVM_SERIAL_LOCK_FILE=/tmp/codeeval-firecracker/firecracker-vsock.lock
CODE_EVAL_MICROVM_RUNTIME_BRIDGE_URL=
CODE_EVAL_MICROVM_RUNTIME_BRIDGE_API_KEY=
CODE_EVAL_MICROVM_RUNTIME_BRIDGE_TIMEOUT_SECONDS=30
CODE_EVAL_MICROVM_RUNTIME_BRIDGE_VERIFY_TLS=true
CODE_EVAL_MICROVM_FIRECRACKER_BIN=/usr/local/bin/firecracker
CODE_EVAL_MICROVM_SNAPSHOT_VMSTATE_PATH=
CODE_EVAL_MICROVM_SNAPSHOT_MEM_PATH=
CODE_EVAL_MICROVM_API_SOCKET_DIR=/tmp/codeeval-firecracker/sockets
CODE_EVAL_MICROVM_RUNTIME_WORKDIR=/tmp/codeeval-firecracker/runs
CODE_EVAL_MICROVM_FIRECRACKER_API_TIMEOUT_SECONDS=5
CODE_EVAL_MICROVM_VSOCK_GUEST_CID=3
CODE_EVAL_MICROVM_VSOCK_PORT=7000
CODE_EVAL_MICROVM_VSOCK_UDS_PATH=/tmp/firecracker-snap-python311.vsock
CODE_EVAL_MICROVM_VSOCK_CONNECT_TIMEOUT_SECONDS=5
CODE_EVAL_MICROVM_ENV_BUILD_STRATEGY=deterministic_key
CODE_EVAL_MICROVM_ENV_BUILD_SCRIPT=/app/microvm/scripts/create_snapshot_with_guest_agent.sh
CODE_EVAL_MICROVM_ENV_BUILD_SNAPSHOT_DIR=/opt/microvm/snapshots
CODE_EVAL_MICROVM_ENV_BUILD_SNAPSHOT_NAME_PREFIX=codeeval
RUNTIME_BRIDGE_EXECUTOR_MODE=local_reference
RUNTIME_BRIDGE_MICROVM_EXECUTE_URL=
RUNTIME_BRIDGE_MICROVM_API_KEY=
RUNTIME_BRIDGE_MICROVM_TIMEOUT_SECONDS=30
RUNTIME_BRIDGE_MICROVM_VERIFY_TLS=true

# ── Database (leave as-is for Docker Compose) ─────────────────────────────
# DATABASE_URL=postgresql+psycopg2://amgs:amgs@postgres:5432/amgs

# ── Redis (leave as-is for Docker Compose) ────────────────────────────────
# REDIS_URL=redis://redis:6379/0

# ── Google Classroom OAuth ────────────────────────────────────────────────────
# Download OAuth 2.0 credentials from GCP Console → APIs & Services → Credentials
# (Desktop App type). Place the downloaded JSON at the path below.
GOOGLE_CREDENTIALS_FILE=backend/app/services/credentials.json
# Token is auto-generated on first OAuth browser flow; path must be writable.
GOOGLE_TOKEN_FILE=backend/app/services/token.json
# (Optional) Pre-fill the default Classroom course ID for this deployment
GOOGLE_CLASSROOM_DEFAULT_COURSE_ID=
