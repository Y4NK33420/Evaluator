# OS / editor
.DS_Store
Thumbs.db
.idea/

# Environment and secrets
.env
.env.*
!.env.example
# Google OAuth credentials — never commit actual secrets
backend/app/services/credentials.json
backend/app/services/token.json
backend/app/services/google_auth/credentials.json
backend/app/services/google_auth/token.json
# Catch any misdirected credential files anywhere in the tree
**/google_auth/credentials.json
**/google_auth/token.json

# Python caches and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.venv/
venv/
backend/.venv/

# Frontend / Node
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Runtime and local test artifacts
.tmp/
*.db
*.sqlite
*.sqlite3
backend/tests/uploads/
backend/tests/uploads_live/
backend/tests/uploads_live_objective/

# MicroVM generated runtime assets
microvm/runtime/*
!microvm/runtime/.gitkeep
microvm/snapshots/*
!microvm/snapshots/.gitkeep
microvm/assets/*.ext4
microvm/assets/*.bin
microvm/assets/*.mem
microvm/assets/*.vmstate

# Generated logs (keep docs/scripts and curated manual artifacts)
logs/*
!logs/README.md
!logs/*.ps1
!logs/manual_artifacts/
!logs/manual_artifacts/**

# Local design/reference repositories (do not commit)
references/
